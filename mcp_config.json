        "DELEGATED_SCOPES": "<YOUR_DELEGATED_SCOPES>",
        "DEVOPSTOOL": "True",
        "EMAILTOOL": "True",
        "ENABLE_DELEGATION": "<YOUR_ENABLE_DELEGATION>",
