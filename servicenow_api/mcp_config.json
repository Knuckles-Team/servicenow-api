{
  "mcpServers": {
    "servicenow-api": {
      "command": "uv",
      "args": [
        "run",
        "servicenow-mcp"
      ],
      "env": {
        "SERVICENOW_INSTANCE": "${SERVICENOW_INSTANCE}",
        "SERVICENOW_USERNAME": "${SERVICENOW_USERNAME}",
        "SERVICENOW_PASSWORD": "${SERVICENOW_PASSWORD}",
        "SERVICENOW_CLIENT_ID": "${SERVICENOW_CLIENT_ID}",
        "SERVICENOW_CLIENT_SECRET": "${SERVICENOW_CLIENT_SECRET}",
        "ACCOUNTTOOL": "${ ACCOUNTTOOL:-True }",
        "ACTIVITY_SUBSCRIPTIONSTOOL": "${ ACTIVITY_SUBSCRIPTIONSTOOL:-True }",
        "AGGREGATETOOL": "${ AGGREGATETOOL:-True }",
        "APPLICATIONTOOL": "${ APPLICATIONTOOL:-True }",
        "ATTACHMENTTOOL": "${ ATTACHMENTTOOL:-True }",
        "AUTHTOOL": "${ AUTHTOOL:-True }",
        "BATCHTOOL": "${ BATCHTOOL:-True }",
        "CHANGE_MANAGEMENTTOOL": "${ CHANGE_MANAGEMENTTOOL:-True }",
        "CICDTOOL": "${ CICDTOOL:-True }",
        "CILIFECYCLETOOL": "${ CILIFECYCLETOOL:-True }",
        "CMDBTOOL": "${ CMDBTOOL:-True }",
        "CUSTOM_APITOOL": "${ CUSTOM_APITOOL:-True }",
        "DATA_CLASSIFICATIONTOOL": "${ DATA_CLASSIFICATIONTOOL:-True }",
        "DEVOPSTOOL": "${ DEVOPSTOOL:-True }",
        "EMAILTOOL": "${ EMAILTOOL:-True }",
        "FLOWSTOOL": "${ FLOWSTOOL:-True }",
        "HRTOOL": "${ HRTOOL:-True }",
        "IMPORT_SETSTOOL": "${ IMPORT_SETSTOOL:-True }",
        "INCIDENTSTOOL": "${ INCIDENTSTOOL:-True }",
        "KNOWLEDGE_MANAGEMENTTOOL": "${ KNOWLEDGE_MANAGEMENTTOOL:-True }",
        "METRICBASETOOL": "${ METRICBASETOOL:-True }",
        "MISCTOOL": "${ MISCTOOL:-True }",
        "OPENAPI_CLIENT_ID": "${OPENAPI_CLIENT_ID}",
        "OPENAPI_PASSWORD": "${OPENAPI_PASSWORD}",
        "OPENAPI_USERNAME": "${OPENAPI_USERNAME}",
        "PLUGINSTOOL": "${ PLUGINSTOOL:-True }",
        "PPMTOOL": "${ PPMTOOL:-True }",
        "PRODUCT_INVENTORYTOOL": "${ PRODUCT_INVENTORYTOOL:-True }",
        "SERVICENOW_RETURN_LIMIT": "${SERVICENOW_RETURN_LIMIT}",
        "SERVICENOW_SSL_VERIFY": "${SERVICENOW_SSL_VERIFY}",
        "SERVICE_QUALIFICATIONTOOL": "${ SERVICE_QUALIFICATIONTOOL:-True }",
        "SOURCE_CONTROLTOOL": "${ SOURCE_CONTROLTOOL:-True }",
        "TABLE_APITOOL": "${ TABLE_APITOOL:-True }",
        "TESTINGTOOL": "${ TESTINGTOOL:-True }",
        "UPDATE_SETSTOOL": "${ UPDATE_SETSTOOL:-True }",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>",
        "DELEGATED_SCOPES": "<YOUR_DELEGATED_SCOPES>",
        "ENABLE_DELEGATION": "<YOUR_ENABLE_DELEGATION>",
        "FASTMCP_SERVER_AUTH_JWT_ALGORITHM": "<YOUR_FASTMCP_SERVER_AUTH_JWT_ALGORITHM>",
        "FASTMCP_SERVER_AUTH_JWT_AUDIENCE": "<YOUR_FASTMCP_SERVER_AUTH_JWT_AUDIENCE>",
        "FASTMCP_SERVER_AUTH_JWT_ISSUER": "<YOUR_FASTMCP_SERVER_AUTH_JWT_ISSUER>",
        "FASTMCP_SERVER_AUTH_JWT_JWKS_URI": "<YOUR_FASTMCP_SERVER_AUTH_JWT_JWKS_URI>",
        "FASTMCP_SERVER_AUTH_JWT_PUBLIC_KEY": "<YOUR_FASTMCP_SERVER_AUTH_JWT_PUBLIC_KEY>",
        "FASTMCP_SERVER_AUTH_JWT_REQUIRED_SCOPES": "<YOUR_FASTMCP_SERVER_AUTH_JWT_REQUIRED_SCOPES>",
        "LLM_API_KEY": "<YOUR_LLM_API_KEY>",
        "LLM_BASE_URL": "<YOUR_LLM_BASE_URL>",
        "MCP_URL": "<YOUR_MCP_URL>",
        "MODEL_ID": "<YOUR_MODEL_ID>",
        "OIDC_CLIENT_ID": "<YOUR_OIDC_CLIENT_ID>",
        "OIDC_CLIENT_SECRET": "<YOUR_OIDC_CLIENT_SECRET>",
        "OIDC_CONFIG_URL": "<YOUR_OIDC_CONFIG_URL>",
        "OPENAPI_CLIENT_SECRET": "<YOUR_OPENAPI_CLIENT_SECRET>",
        "SERVICENOW_AUDIENCE": "<YOUR_SERVICENOW_AUDIENCE>"
      }
    }
  }
}
