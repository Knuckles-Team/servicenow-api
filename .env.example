# ServiceNow Environment Variables

# Connection
SERVICENOW_INSTANCE=https://your-instance.service-now.com

# Authentication (choose one method)
# Method 1: Basic Auth (username/password + optional OAuth client credentials)
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# Method 2: OIDC Delegation — RFC 8693 Token Exchange (enterprise SSO)
# ENABLE_DELEGATION=true
# AUDIENCE=https://your-instance.service-now.com
# DELEGATED_SCOPES=api

# SSL Verification
SERVICENOW_SSL_VERIFY=True

# MCP Server Configuration
HOST=0.0.0.0
PORT=9608
TRANSPORT=stdio

# Debug
DEBUG=False
PYTHONUNBUFFERED=1
